@manifest.route("/order/<order_number>/test-pickup", methods=["POST"])
@login_required
def test_pickup_email(order_number):
    day = request.form.get("day", "today").strip().lower()
    day_offset = 1 if day == "tomorrow" else 0
    order = None
    try:
        order = get_order_detail(order_number, day_offset=day_offset)
    except Exception:
        order = None
    if not order:
        order = _find_order_in_snapshots(order_number)
    if not order:
        abort(404)

    order = _normalise_order(order)

    subject = f"TEST Pickup Info - {order_number}"
    body = f"""
    <p>Test pickup info email</p>
    <p><strong>Customer:</strong> {order.get('customer_name') or 'Customer'}</p>
    <p><strong>Pickup location:</strong> {order.get('pickup_location') or '-'}</p>
    <p><strong>Pickup date:</strong> {order.get('pickup_date') or '-'}</p>
    <p><strong>Pickup time:</strong> {order.get('pickup_time') or '-'}</p>
    <p><strong>Flight:</strong> {order.get('flight_slot_full') or order.get('flight_slot') or '-'}</p>
    """
    send_email("edsaleh98@gmail.com", subject, body)
    flash(f"Test pickup email sent for {order_number}")
    return redirect(url_for("manifest.order_detail", order_number=order_number, day=day))

