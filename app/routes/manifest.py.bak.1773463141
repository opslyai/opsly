@manifest.route("/export")
@login_required
def export_pdf():
    day = request.args.get("day", "today").strip().lower()
    slot_iso = request.args.get("slot", "").strip()
    day_offset = 1 if day == "tomorrow" else 0

    manifests = _load_or_build_snapshot(day_offset)
    selected = None
    for m in manifests:
        if m.get("slot_iso") == slot_iso:
            selected = m
            break

    if not selected:
        abort(404)

    buffer = BytesIO()
    pdf = canvas.Canvas(buffer, pagesize=A4)
    width, height = A4
    y = height - 50

    pdf.setFont("Helvetica-Bold", 18)
    pdf.drawString(40, y, "Opsly Manifest")
    y -= 24

    pdf.setFont("Helvetica", 11)
    pdf.drawString(40, y, f"Flight: {selected['slot_display_full']}")
    y -= 16
    pdf.drawString(40, y, f"Day: {day.title()}")
    y -= 16
    pdf.drawString(40, y, f"Total Pax: {selected['total_pax']}")
    y -= 16
    pdf.drawString(40, y, f"Total Weight: {selected['total_weight']} kg" if selected['total_weight'] is not None else "Total Weight: Not available")
    y -= 24

    for pickup in selected.get("pickup_summary", []):
        if y < 80:
            pdf.showPage()
            y = height - 50
        pdf.drawString(55, y, f"{pickup['date']} · {pickup['time']} · {pickup['location']}")
        y -= 14

    y -= 10

    for idx, order in enumerate(selected["orders"], start=1):
        if y < 120:
            pdf.showPage()
            y = height - 50

        pdf.setFont("Helvetica-Bold", 12)
        pdf.drawString(40, y, f"{idx}. {order['customer_name']} ({order['order_number']})")
        y -= 16

        pdf.setFont("Helvetica", 10)
        pdf.drawString(55, y, f"Pickup: {order.get('pickup_date') or '-'} · {order.get('pickup_time') or '-'} · {order.get('pickup_location') or '-'}")
        y -= 14
        pdf.drawString(55, y, f"Pax: {order['pax_total']}")
        y -= 18

    pdf.save()
    buffer.seek(0)

    filename = f"opsly_manifest_{selected['slot'].replace(':','')}_{day}.pdf"
    return send_file(buffer, as_attachment=True, download_name=filename, mimetype="application/pdf")
